# ============================================================
# ANSPORTIA backend (NestJS) — copy to backend/.env
# ============================================================

# ----- Database (Prisma → Supabase Postgres) -----
# Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ----- Supabase (Storage + JWT verification) -----
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — backend only
SUPABASE_STORAGE_BUCKET=ansportia-documents
# Settings > API > JWT Secret — used to verify Supabase access tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ----- API -----
API_PORT=4000
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=10
