# ============================================================
# ANSPORTIA — environment variables (copy to .env and fill in)
# ============================================================

# ----- Supabase (Postgres + Auth + Storage) -----
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service role key is SECRET — backend only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket name (create this bucket in Supabase > Storage, keep it PRIVATE)
SUPABASE_STORAGE_BUCKET=ansportia-documents

# ----- Database (Prisma) -----
# Supabase Dashboard > Project Settings > Database > Connection string
# Use the "Connection pooling" string (port 6543) for the app runtime:
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct connection (port 5432) for migrations:
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ----- Backend (NestJS / apps/api) -----
API_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# Upload limits
MAX_UPLOAD_MB=10

# ----- Frontend (Next.js / apps/web) -----
# These are exposed to the browser — only use public keys here
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
